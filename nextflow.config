
params {
    // preset params:
    rundir = "${launchDir.baseName}"
    genome = "hg38"

    // Local-only VarSeq credentials config.
    // Can be overridden with --varseq_credentials_config /path/to/file
    varseq_credentials_config = "/lnx01_data2/shared/users/raspau/varseq_credentials.config.txt"
}

def varseqCredentialsConfig = new File(params.varseq_credentials_config)

if (varseqCredentialsConfig.exists()) {
    includeConfig varseqCredentialsConfig
} else {
    println "[WARN] VarSeq credentials config not found: ${params.varseq_credentials_config}"
}

switch (params.genome) {
    case 'hg38':
    def sharedConfig = new File('/data/configs/nextflowLRS.config')
    if (sharedConfig.exists()) {
        includeConfig sharedConfig
    }
    break;

    case 't2t':
    def sharedConfig = new File('/data/configs/nextflowLRS_T2T.config')
    if (sharedConfig.exists()) {
        includeConfig sharedConfig
    }
    break;
}
